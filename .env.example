# Supabase — copy from: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase direct connection — copy from: Project Settings → Database → Connection string → URI
# Used by drizzle-kit for schema migrations (not the pooler URL)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-REGION.pooler.supabase.com:5432/postgres
